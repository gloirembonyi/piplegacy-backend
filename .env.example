# Required in production (generate: openssl rand -base64 32)
SESSION_SECRET=generate-a-random-32-char-minimum-secret-here

# App URL (production)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Google OAuth - in Google Cloud Console add redirect URIs:
#   https://YOUR-DOMAIN.vercel.app/api/auth/google/callback
#   http://localhost:3000/api/auth/google/callback
# (same redirect URI is reused for the desktop flow - see DESKTOP_DEEP_LINK_URL below,
#  Google itself only ever redirects back here, never to a custom URI scheme)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional - legacy; email/password accounts use signup API
AUTH_DEMO_PASSWORD=

# piplegacy-desktop - custom URI scheme the Google callback redirects to after minting a
# one-time exchange code (default matches piplegacy-desktop's tauri.conf.json deep-link config)
DESKTOP_DEEP_LINK_URL=piplegacy://auth-callback

# CORS - comma-separated extra origins allowed to call this API with credentials (e.g. a
# separately-hosted web frontend). The Tauri desktop app's origins are always allowed.
ALLOWED_ORIGINS=

# APIs (server-only - never use NEXT_PUBLIC_ for secrets)
FINNHUB_API_KEY=
# Live quotes & news (free tier). Candle data uses FMP / Alpha Vantage / TradingView embed.
# Also powers economic calendar (optional - demo data if unset)
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=
# Chart analysis + Market Agent (Gemini). Prefer flash-lite on free tier.
# Get keys at https://aistudio.google.com/apikey - add GEMINI_API_KEY_2/_3/_4/_5 for rotation.
GEMINI_API_KEY=
# Optional overrides (defaults: gemini-2.5-flash-lite)
# GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-2.5-flash-lite
# Max parallel AI HTTP calls on free tier (default 2 - prevents 429 when 8 specialists run)
# AI_MAX_CONCURRENT_CALLS=2

# Google Custom Search (agent web research - search entire web)
# 1. Create a Programmable Search Engine: https://programmablesearchengine.google.com/
#    (default cx in code: 50b16243c51df457f - override with GOOGLE_CSE_CX if needed)
# 2. Enable Custom Search API + create API key: https://console.cloud.google.com/apis/library/customsearch.googleapis.com
GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CSE_CX=50b16243c51df457f
# Do NOT use NEXT_PUBLIC_GEMINI_API_KEY (exposes key to the browser)

# Stripe (use TEST keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Optional - for subscription cancel/renew webhooks (stripe listen --forward-to localhost:3000/api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# Per-user data persistence (Vercel KV / Upstash - required on Vercel for rate limits + token usage)
# Vercel: Dashboard → Storage → Create → Upstash Redis → Connect to this project
# (auto-injects KV_REST_API_URL and KV_REST_API_TOKEN - redeploy after linking)
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternative Upstash naming (also supported):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Convex - optional conversation store for Market Agent (recommended)
# 1. Dashboard: https://dashboard.convex.dev → create project "market-ai"
# 2. Settings → Deploy Key → copy CONVEX_DEPLOY_KEY into .env.local
# 3. Deploy functions: pnpm convex:deploy
# 4. Set URL from dashboard (e.g. https://fantastic-raccoon-65.convex.cloud)
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# ────────────────────────────────────────────────────────────────
# Auto-Trader bot (multi-agent pipeline + broker execution)
# ────────────────────────────────────────────────────────────────

# Vercel Cron secret - Vercel sends this as `Authorization: Bearer <CRON_SECRET>`.
# Required for /api/cron/scan. Hobby plan allows one cron/day (see vercel.json).
# Pro plan can use */1 * * * * for minute-level scans and trigger-pending.
CRON_SECRET=

# Global hard-gate for LIVE broker orders. Defaults to false. When false,
# any strategy in "live" mode is rejected by the risk guard even if the user
# flipped its toggle. Flip to true ONLY when you understand the risk.
BOT_LIVE_TRADING_ENABLED=false

# Scan pipeline (bot / chart analysis)
# Default: TypeScript - 8 in-process specialists in lib/agent/specialists/* (no Python required).
# Legacy Python sidecar / Vercel Python is opt-in only:
#   PIPELINE_USE_PYTHON=true
#   PYTHON_AGENT_URL=http://127.0.0.1:8765   # local sidecar (npm run python-agent:start)
# PYTHON_AGENT_URL=disabled
# PYTHON_AGENT_SECRET=

# OPTIONAL - system-wide fallback broker keys. Per-user keys (entered via the
# Brokers page and encrypted with SESSION_SECRET) are always preferred and
# these are only useful for local development / single-tenant deployments.
# ALPACA_KEY_ID=
# ALPACA_SECRET_KEY=
# OANDA_API_TOKEN=
# OANDA_ACCOUNT_ID=
